#!/usr/bin/env bash
# Real git pre-push hook. Installed by `make install-hooks`. Mirrors what the
# Claude Code PreToolUse hook in .claude/settings.json does, so the same scan
# runs whether the push is driven by Claude or by direct CLI use.
#
# Git pipes `<local-ref> <local-sha> <remote-ref> <remote-sha>` lines on stdin
# for each ref being pushed; we ignore them and let the scanner inspect
# `@{u}..HEAD`, which covers the typical case (one branch tracking origin).
exec "$(git rev-parse --show-toplevel)/.claude/scripts/check-public-safe.sh" push
